# GDB Frontend Environment Variables
# Copy this file to .env and update the values as needed

# App Configuration
VITE_APP_NAME=GDB Banking
VITE_APP_VERSION=1.0.0

# ============================================
# Backend Service URLs
# ============================================

# Accounts Service (Port: 8001)
VITE_ACCOUNTS_SERVICE_URL=http://localhost:8001

# Transactions Service (Port: 8002)
VITE_TRANSACTIONS_SERVICE_URL=http://localhost:8002

# Users Service (Port: 8003)
VITE_USERS_SERVICE_URL=http://localhost:8003

# Auth Service (Port: 8004)
VITE_AUTH_SERVICE_URL=http://localhost:8004

# Aadhar Verification Service (Port: 8005)
VITE_AADHAR_SERVICE_URL=http://localhost:8005

# Company CRV Service (Port: 8006)
VITE_COMPANY_CRV_SERVICE_URL=http://localhost:8006

# Notification Service (Port: 8007)
VITE_NOTIFICATION_SERVICE_URL=http://localhost:8007

# Central Payment Gateway (Port: 8008)
VITE_PAYMENT_GATEWAY_URL=http://localhost:8008

# Credit Cards Service (Port: 8009)
VITE_CREDIT_CARDS_SERVICE_URL=http://localhost:8009

# Loan Service (Port: 8012)
VITE_LOAN_SERVICE_URL=http://localhost:8012

# AI Assistant Service (Port: 8013)
VITE_AI_ASSISTANT_URL=http://localhost:8013

